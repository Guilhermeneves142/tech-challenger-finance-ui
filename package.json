{
  "name": "@vandrei/finance-ui",
  "version": "0.1.1",
  "description": "Design system do FinanceApp — tokens (CSS variables), tipografia e componentes React baseados em Tailwind v4 + Base UI. Funciona em Next.js e React/Vite.",
  "license": "MIT",
  "author": "vandrei",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./typography.css": "./dist/typography.css"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --minify && node ./scripts/copy-css.mjs",
    "build": "npm run clean && npm run build:js && npm run build:css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@vandrei/finance-ui": "^0.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react-day-picker": "^9.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "rimraf": "^6",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "tsup": "^8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "keywords": [
    "design-system",
    "ui",
    "react",
    "nextjs",
    "tailwindcss",
    "base-ui",
    "components"
  ],
  "publishConfig": {
    "access": "public"
  }
}
